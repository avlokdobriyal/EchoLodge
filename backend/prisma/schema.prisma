generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String?  // nullable: OAuth (Google) users have no local password
  name      String?
  // "USER" or "ADMIN". Stored as a plain string for portability; the app only
  // ever grants elevated access when this exactly equals "ADMIN".
  role      String   @default("USER")
  createdAt DateTime @default(now())
  reviews   Review[]
  bookings  Booking[]
}

model Review {
  id          Int      @id @default(autoincrement())
  guestName   String
  roomType    String
  reviewText  String
  rating      Int? // 1-5 stars; nullable so pre-rating rows survive
  createdAt   DateTime @default(now())
  // nullable so existing rows survive the migration; new reviews are stamped
  // with the authenticated user.
  authorId    Int?
  author      User?    @relation(fields: [authorId], references: [id])

  // --- AI-generated metadata (populated by Gemini on submission; all nullable
  // so a review still saves when the AI call fails) ------------------------
  sentiment      String? // POSITIVE | NEUTRAL | NEGATIVE
  aiTags         String[] @default([]) // internal categorisation, admin-only
  suggestedReply String? // AI draft reply, admin-only
  adminReply     String? // the reply the admin actually published
  adminReplied   Boolean  @default(false)
  repliedAt      DateTime? // when the admin published (or last updated) the reply
}

model Room {
  id            Int       @id @default(autoincrement())
  name          String
  category      String
  description   String
  pricePerNight Float
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model Booking {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  roomId       Int
  room         Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  checkInDate  DateTime
  checkOutDate DateTime
  totalPrice   Float
  status       String   @default("CONFIRMED")
  createdAt    DateTime @default(now())

  @@index([roomId])
  @@index([userId])
}
